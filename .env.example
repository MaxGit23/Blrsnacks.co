# ──────────────────────────────────────────────────────────────────────────────
# Blrsnacks.co — Docker Compose Environment Variables (Production)
# Copy to .env next to docker-compose.yml
# ──────────────────────────────────────────────────────────────────────────────

# ─── Supabase / PostgreSQL ───────────────────────────────────────────────────
# Transaction mode pooler (port 6543) — used by the running app
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (port 5432) — used by Prisma Migrate only
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN_SECONDS=900
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=https://blrsnacks.co
