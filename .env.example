# ──────────────────────────────────────────────────────────────────────────────
# Blrsnacks.co — Docker Compose Environment Variables (Production)
# Copy to .env next to docker-compose.yml
# ──────────────────────────────────────────────────────────────────────────────

# ─── MySQL ───────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=blrsnacks
MYSQL_USER=blrsnacks
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN_SECONDS=900
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=https://blrsnacks.co
