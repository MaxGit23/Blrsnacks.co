# ──────────────────────────────────────────────────────────────────────────────
# Blrsnacks.co Backend — Environment Variables (Production Example)
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string

# Transaction mode pooler (port 6543) — used by the running app
# Add ?pgbouncer=true for Prisma to work in transaction mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (port 5432) — used by Prisma Migrate & Prisma Studio only
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── JWT Authentication ─────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN_SECONDS=900
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# ─── Google OAuth (optional — leave blank to disable) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://blrsnacks.co
